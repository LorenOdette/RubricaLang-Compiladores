rubrica examen_final {
    criterio teoria peso 40 {
        nivel "excelente" 10;
        nivel "bueno" 7;
        nivel "regular" 4;
    };
    criterio practica peso 60 {
        nivel "excelente" 10;
        nivel "bueno" 7;
    };
}

